# OAuth Refresh Daemon — VM-specific config
# Copy to .env and fill in values

# Port: 8092 for VM 102, 8093 for VM 105
PORT=8092

# Google OAuth app credentials (from ~/.google-oauth-client.json by default)
# GOOGLE_CLIENT_SECRETS_FILE=/home/marcus/.google-oauth-client.json

# Scopes (comma-separated)
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive,https://mail.google.com/

# Redirect URI must match what's registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8092/oauth/google/callback

# GitHub PAT (or set in ~/.secrets.env)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Token refresh interval in minutes (default: 30)
# REFRESH_INTERVAL_MINUTES=30

# Token storage path (default: ~/.oauth-tokens.json)
# TOKEN_PATH=/home/marcus/.oauth-tokens.json
