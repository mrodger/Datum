# OAuth Refresh Daemon — VM-specific config
# Copy to .env and fill in values

# Port: 8092 for prod VM, 8093 for test VM
PORT=8092

# Shared secret for /oauth/tokens endpoint (generate with: openssl rand -hex 32)
DAEMON_SECRET=your-secret-here

# Google OAuth app credentials (from $HOME/.google-oauth-client.json by default)
# GOOGLE_CLIENT_SECRETS_FILE=$HOME/.google-oauth-client.json

# Scopes (comma-separated)
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive,https://mail.google.com/

# Redirect URI must match what's registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8092/oauth/google/callback

# GitHub PAT (or set in $HOME/.secrets.env)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Token refresh interval in minutes (default: 30)
# REFRESH_INTERVAL_MINUTES=30

# Token storage path (default: $HOME/.oauth-tokens.json)
# TOKEN_PATH=$HOME/.oauth-tokens.json
